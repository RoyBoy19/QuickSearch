# Server
HOST=0.0.0.0
PORT=3000

# Set this to the public origin when deploying behind a reverse proxy.
# Example: https://quicksearch.example.com
PUBLIC_ORIGIN=

# Keep this false for public deployments. Turn it on only for trusted local testing.
ALLOW_PRIVATE_NETWORKS=false

# Limits
MAX_HTML_REWRITE_BYTES=12582912
MAX_REQUEST_BODY_BYTES=20971520
MAX_REDIRECTS=8
SESSION_TTL_MS=21600000

# Optional upstream browser identity.
UPSTREAM_USER_AGENT=
